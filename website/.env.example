# Qdrant
QDRANT_URL=
QDRANT_API_KEY=

# Gemini
GEMINI_API_KEY=

# Appwrite (server-side function invocation)
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# Appwrite function IDs
AUDIOFUNCTION_ID=
IMAGEFUNCTION_ID=
CLUSTERINGFUNCTION_ID=
PROCESSSEGMENTFUNCTION_ID=
CUSTOMREPORTFUNCTION_ID=

# Optional CORS override for API responses
WEB_API_ALLOW_ORIGIN=*
